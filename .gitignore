# ============================================
# VisionPass AI门禁系统 — .gitignore
# ============================================

# --- 内核模块编译产物 ---
*.ko
*.o
*.mod.c
*.mod.o
*.o.cmd
*.ko.cmd
modules.order
Module.symvers
.tmp_versions/

# --- 测试程序编译产物 ---
*.test
rc522_test
servo_test
ir_sensor_test
rc522_card_diag
rc522_diag
rc522_scan
rc522_write_verify
simple_test
servo_test_simple
ir_sensor_test

# --- 编辑器/IDE ---
*.swp
*.swo
*~
.vscode/
.idea/

# --- CMake构建产物 ---
build/
build-arm/
build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt
!config/*.cmake

# --- Qt构建产物 ---
*.pro.user
*.pro.user.*
moc_*.cpp
moc_*.o
ui_*.h
qrc_*.cpp
qrc_*.o

# --- 日志和临时文件 ---
*.log
*.tmp
*.pid

# --- 部署产物 ---
deploy/
*.tar.gz
*.tar.bz2

# --- 系统文件 ---
.DS_Store
Thumbs.db

# --- Claude AI配置 ---
.claude/plans/

# ============================================
# 原版参考代码（已有独立git仓库）
# ============================================
VisionPass/
VisionPass-fork/

# ============================================
# 网盘大文件（模型文件、系统镜像等）
# ============================================
# 这些文件存放于网盘，不纳入git版本控制
# 具体清单见 README.md "外部资源" 章节
